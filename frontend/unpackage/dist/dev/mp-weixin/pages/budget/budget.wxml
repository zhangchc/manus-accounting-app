<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="nav-bar"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="nav-back" bindtap="__e"><text>‹</text></view><text class="nav-title">预算管理</text><view class="nav-placeholder"></view></view><view class="month-selector"><view data-event-opts="{{[['tap',[['prevMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>‹</text></view><text class="month-text">{{monthName}}</text><view data-event-opts="{{[['tap',[['nextMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>›</text></view></view><scroll-view class="content-scroll" scroll-y="{{true}}"><block wx:if="{{totalBudget>0}}"><view class="ring-card"><view class="ring-area"><canvas class="ring-canvas" style="{{'width:'+('360rpx')+';'+('height:'+('360rpx')+';')}}" canvas-id="ringChart"></canvas><view class="ring-center"><text class="ring-percent">{{budgetPercent+"%"}}</text><text class="ring-label">已使用</text></view></view><view class="budget-data-row"><view class="budget-data-item"><text class="budget-data-label">预算</text><text class="budget-data-value">{{"¥"+$root.m0}}</text></view><view class="budget-data-item"><text class="budget-data-label">已花</text><text class="budget-data-value expense">{{"¥"+$root.m1}}</text></view><view class="budget-data-item"><text class="budget-data-label">{{budgetRemain>=0?'剩余':'超支'}}</text><text class="{{['budget-data-value',budgetRemain>=0?'safe':'over']}}">{{'¥'+$root.m2+''}}</text></view></view></view></block><view data-event-opts="{{[['tap',[['editBudget',['$event']]]]]}}" class="set-budget-btn" bindtap="__e"><text class="set-budget-text">{{totalBudget>0?'修改预算':'设置月度预算'}}</text></view><block wx:if="{{totalBudget>0}}"><view class="detail-card"><text class="detail-title">预算使用详情</text><view class="progress-section"><view class="progress-header"><text class="progress-label">总体进度</text><text class="{{['progress-percent',statusClass]}}">{{budgetPercent+"%"}}</text></view><view class="progress-bar-bg"><view class="{{['progress-bar',statusClass]}}" style="{{'width:'+($root.g0+'%')+';'}}"></view></view><text class="progress-hint">{{dailyAvgHint}}</text></view><view class="status-legend"><view class="status-item"><view class="status-dot safe"></view><text class="status-text">正常 (0-60%)</text></view><view class="status-item"><view class="status-dot warn"></view><text class="status-text">警告 (60-80%)</text></view><view class="status-item"><view class="status-dot over"></view><text class="status-text">超支 (80%+)</text></view></view></view></block><block wx:if="{{totalBudget<=0}}"><view class="empty-card"><text class="empty-icon">💰</text><text class="empty-title">还没有设置预算</text><text class="empty-desc">设置月度预算，合理规划每月开支</text></view></block><view style="height:40rpx;"></view></scroll-view><block wx:if="{{showModal}}"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="modal-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="modal-content" catchtap="__e"><text class="modal-title">设置月度预算</text><view class="modal-input-wrap"><text class="modal-symbol">¥</text><input class="modal-input" type="digit" placeholder="请输入预算金额" focus="{{true}}" data-event-opts="{{[['input',[['__set_model',['','budgetInput','$event',[]]]]]]}}" value="{{budgetInput}}" bindinput="__e"/></view><view class="modal-btns"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="modal-btn cancel" bindtap="__e"><text>取消</text></view><view data-event-opts="{{[['tap',[['saveBudget',['$event']]]]]}}" class="modal-btn confirm" bindtap="__e"><text>确定</text></view></view></view></view></block></view>