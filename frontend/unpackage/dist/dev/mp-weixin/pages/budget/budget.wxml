<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="nav-bar"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="nav-back" bindtap="__e"><text>‹</text></view><text class="nav-title">预算管理</text><view class="nav-placeholder"></view></view><view class="month-selector"><view data-event-opts="{{[['tap',[['prevMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>‹</text></view><text class="month-text">{{monthName}}</text><view data-event-opts="{{[['tap',[['nextMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>›</text></view></view><view class="budget-card"><view class="budget-header"><text class="budget-title">月度总预算</text><view data-event-opts="{{[['tap',[['editBudget',['$event']]]]]}}" class="budget-edit" bindtap="__e"><text>{{totalBudget>0?'修改':'设置'}}</text></view></view><block wx:if="{{totalBudget>0}}"><view class="budget-amount"><text class="budget-value">{{"¥"+$root.m0}}</text><view class="budget-progress"><view class="progress-info"><text class="progress-used">{{"已用 ¥"+$root.m1}}</text><text class="{{['progress-remain',(budgetRemain<0)?'over':'']}}">{{''+(budgetRemain>=0?'剩余 ¥'+$root.m2:'超支 ¥'+$root.m3)+''}}</text></view><view class="progress-bar-bg"><view class="{{['progress-bar',(budgetPercent>80)?'over':'',(budgetPercent>100)?'danger':'']}}" style="{{'width:'+(budgetPercent+'%')+';'}}"></view></view></view></view></block><block wx:else><view class="budget-empty"><text class="budget-empty-text">还没有设置预算哦</text><text class="budget-empty-hint">设置预算，合理规划每月开支</text></view></block></view><block wx:if="{{showModal}}"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="modal-mask" bindtap="__e"><view data-event-opts="{{[['tap',[['',['$event']]]]]}}" class="modal-content" catchtap="__e"><text class="modal-title">设置月度预算</text><view class="modal-input-wrap"><text class="modal-symbol">¥</text><input class="modal-input" type="digit" placeholder="请输入预算金额" focus="{{true}}" data-event-opts="{{[['input',[['__set_model',['','budgetInput','$event',[]]]]]]}}" value="{{budgetInput}}" bindinput="__e"/></view><view class="modal-btns"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="modal-btn cancel" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['saveBudget',['$event']]]]]}}" class="modal-btn confirm" bindtap="__e">确定</view></view></view></view></block></view>