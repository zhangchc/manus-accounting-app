<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="nav-bar"><text class="nav-title">统计分析</text></view><view class="month-selector"><view data-event-opts="{{[['tap',[['prevMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>‹</text></view><text class="month-text">{{monthName}}</text><view data-event-opts="{{[['tap',[['nextMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>›</text></view></view><view class="type-tabs"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="{{['tab-item',(type===1)?'active':'']}}" bindtap="__e"><text>支出</text></view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['tab-item',(type===2)?'active':'']}}" bindtap="__e"><text>收入</text></view></view><view class="summary-card"><view class="summary-item"><text class="summary-label">{{type===1?'总支出':'总收入'}}</text><text class="summary-amount">{{"¥"+$root.m0}}</text></view><view class="summary-item"><text class="summary-label">{{type===1?'日均支出':'日均收入'}}</text><text class="summary-amount sub">{{"¥"+$root.m1}}</text></view></view><view class="section"><view class="section-header"><text class="section-title">分类排行</text></view><block wx:if="{{$root.g0>0}}"><view class="rank-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="categoryId"><view class="rank-item"><view class="rank-left"><text class="rank-icon">{{item.$orig.categoryIcon}}</text><view class="rank-info"><view class="rank-name-row"><text class="rank-name">{{item.$orig.categoryName}}</text><text class="rank-percent">{{item.$orig.percent}}</text></view><view class="rank-bar-bg"><view class="rank-bar" style="{{'width:'+(item.$orig.percent)+';'+('background:'+(item.m2)+';')}}"></view></view></view></view><text class="rank-amount">{{"¥"+item.m3}}</text></view></block></view></block><block wx:else><view class="empty-state"><text class="empty-icon">📊</text><text class="empty-text">暂无数据</text></view></block></view><view class="section"><view class="section-header"><text class="section-title">每日趋势</text></view><view class="trend-chart"><view class="chart-bars"><block wx:for="{{$root.l1}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="chart-bar-wrapper"><view class="chart-bar" style="{{'height:'+(item.m4+'rpx')+';'+('background:'+(type===1?'#F5707A':'#5CC9A7')+';')}}"></view><block wx:if="{{(index+1)%5===0||index===0}}"><text class="chart-label">{{index+1}}</text></block></view></block></view></view></view></view>