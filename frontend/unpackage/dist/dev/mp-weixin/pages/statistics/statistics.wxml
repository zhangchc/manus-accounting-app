<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="nav-bar"><text class="nav-title">统计分析</text></view><view class="month-selector"><view data-event-opts="{{[['tap',[['prevMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>‹</text></view><text class="month-text">{{monthName}}</text><view data-event-opts="{{[['tap',[['nextMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>›</text></view></view><view class="type-switch"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="{{['type-item',(type===1)?'active':'']}}" bindtap="__e"><text>支出</text></view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['type-item',(type===2)?'active':'']}}" bindtap="__e"><text>收入</text></view></view><scroll-view class="content-scroll" scroll-y="{{true}}"><view class="total-card"><view class="total-accent"></view><view class="total-body"><text class="total-label">{{"本月总"+(type===1?'支出':'收入')}}</text><text class="total-amount">{{"¥"+$root.m0}}</text><view class="total-sub"><text class="total-sub-text">{{"共 "+$root.g0+" 个分类"}}</text><text class="total-sub-text">{{"日均 ¥"+$root.m1}}</text></view></view></view><block wx:if="{{$root.g1>0}}"><view class="chart-card"><text class="chart-title">分类占比</text><view class="pie-area"><canvas class="pie-canvas" style="{{'width:'+('400rpx')+';'+('height:'+('400rpx')+';')}}" canvas-id="pieChart"></canvas><view class="pie-center"><text class="pie-center-amount">{{"¥"+$root.m2}}</text><text class="pie-center-label">{{$root.g2+"个分类"}}</text></view></view><view class="legend-grid"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="legend-item"><view class="legend-dot" style="{{'background:'+(pieColors[index])+';'}}"></view><text class="legend-name">{{item.$orig.categoryName}}</text><text class="legend-percent">{{item.$orig.percent}}</text><text class="legend-amount">{{"¥"+item.m3}}</text></view></block></view></view></block><block wx:if="{{$root.g3>0}}"><view class="chart-card"><text class="chart-title">每日趋势</text><view class="bar-chart"><block wx:for="{{$root.l1}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="bar-item"><view class="bar-value-wrap"><block wx:if="{{item.$orig.amount>0}}"><text class="bar-value">{{item.$orig.amount>999?item.g4+'k':item.g5}}</text></block></view><view class="bar-col-wrap"><view class="{{['bar-col',index%2===0?'bar-blue':'bar-purple']}}" style="{{'height:'+(item.m4+'rpx')+';'}}"></view></view><block wx:if="{{(index+1)%5===0||index===0}}"><text class="bar-label">{{index+1}}</text></block><block wx:else><text class="bar-label"></text></block></view></block></view></view></block><block wx:if="{{$root.g6>0}}"><view class="chart-card"><text class="chart-title">分类排行</text><view class="rank-list"><block wx:for="{{$root.l2}}" wx:for-item="item" wx:for-index="index" wx:key="categoryId"><view class="rank-item"><view class="rank-left"><view class="rank-icon-wrap" style="{{'background:'+(item.m5)+';'}}"><image class="rank-icon-img" src="{{item.m6}}" mode="aspectFit"></image></view><view class="rank-info"><view class="rank-name-row"><text class="rank-name">{{item.$orig.categoryName}}</text><text class="rank-percent-text">{{item.$orig.percent}}</text></view><view class="rank-bar-bg"><view class="rank-bar" style="{{'width:'+(item.$orig.percent)+';'+('background:'+(pieColors[index%item.g7])+';')}}"></view></view></view></view><text class="rank-amount">{{"¥"+item.m7}}</text></view></block></view></view></block><block wx:if="{{$root.g8===0}}"><view class="empty-state"><image class="empty-icon-img" style="width:120rpx;height:120rpx;opacity:0.5;" src="/static/category/qita_out.png" mode="aspectFit"></image><text class="empty-text">{{"本月暂无"+(type===1?'支出':'收入')+"记录"}}</text></view></block><view style="height:120rpx;"></view></scroll-view></view>