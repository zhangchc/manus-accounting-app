<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="nav-bar"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="nav-back" bindtap="__e"><text>‹</text></view><text class="nav-title">月度账单</text><view class="nav-placeholder"></view></view><view class="month-selector"><view data-event-opts="{{[['tap',[['prevMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>‹</text></view><text class="month-text">{{monthName}}</text><view data-event-opts="{{[['tap',[['nextMonth',['$event']]]]]}}" class="month-arrow" bindtap="__e"><text>›</text></view></view><view class="summary-card"><view class="summary-row"><view class="summary-col"><text class="summary-label">收入</text><text class="summary-value">{{"¥"+$root.m0}}</text></view><view class="summary-divider"></view><view class="summary-col"><text class="summary-label">支出</text><text class="summary-value">{{"¥"+$root.m1}}</text></view><view class="summary-divider"></view><view class="summary-col"><text class="summary-label">结余</text><text class="summary-value">{{"¥"+$root.m2}}</text></view></view></view><scroll-view class="bill-scroll" scroll-y="{{true}}"><block wx:for="{{$root.l1}}" wx:for-item="day" wx:for-index="__i0__" wx:key="date"><view class="day-group"><view class="day-header"><view class="day-left"><text class="day-date">{{day.m3}}</text><text class="day-week">{{day.$orig.weekDay}}</text></view><view class="day-right"><block wx:if="{{day.$orig.dayExpense>0}}"><text class="day-expense">{{"支出 ¥"+day.m4}}</text></block><block wx:if="{{day.$orig.dayIncome>0}}"><text class="day-income">{{'收入 ¥'+day.m5}}</text></block></view></view><view class="record-card"><block wx:for="{{day.l0}}" wx:for-item="item" wx:for-index="__i1__" wx:key="id"><view data-event-opts="{{[['longpress',[['onRecordLongPress',['$0'],[[['dailyList','date',day.$orig.date],['records','id',item.$orig.id]]]]]]]}}" class="record-item" bindlongpress="__e"><view class="record-icon-wrap" style="{{'background:'+(item.m6)+';'}}"><image class="record-icon-img" src="{{item.m7}}" mode="aspectFit"></image></view><view class="record-info"><text class="record-category">{{item.$orig.categoryName}}</text><block wx:if="{{item.$orig.remark}}"><text class="record-remark">{{item.$orig.remark}}</text></block></view><text class="{{['record-amount',item.$orig.type===1?'expense':'income']}}">{{''+(item.$orig.type===1?'-':'+')+"¥"+item.m8+''}}</text></view></block></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon-img" style="width:120rpx;height:120rpx;opacity:0.5;" src="/static/category/qita_out.png" mode="aspectFit"></image><text class="empty-text">本月暂无记录</text></view></block><view style="height:40rpx;"></view></scroll-view></view>