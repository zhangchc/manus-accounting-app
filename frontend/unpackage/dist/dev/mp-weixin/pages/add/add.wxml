<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="nav-bar"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="nav-back" bindtap="__e"><text class="nav-back-icon">‹</text></view><text class="nav-title">{{isEdit?'编辑记录':'记一笔'}}</text><view class="nav-placeholder"></view></view><view class="type-switch"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="{{['type-item',(type===1)?'active':'']}}" bindtap="__e"><text>支出</text></view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['type-item',(type===2)?'active':'']}}" bindtap="__e"><text>收入</text></view></view><view class="category-section"><scroll-view class="category-scroll" scroll-y="{{true}}"><view class="category-grid"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['selectCategory',['$0'],[[['categoryList','id',item.$orig.id]]]]]]]}}" class="{{['category-item',(selectedCategory===item.$orig.id)?'active':'']}}" bindtap="__e"><view class="{{['category-icon-wrap',(selectedCategory===item.$orig.id)?'active':'']}}" style="{{'background:'+(item.m0)+';'}}"><image class="category-icon-img" src="{{item.m1}}" mode="aspectFit"></image><block wx:if="{{selectedCategory===item.$orig.id}}"><view class="category-check"><text class="check-icon">✓</text></view></block></view><text class="category-name">{{item.$orig.name}}</text></view></block></view></scroll-view></view><view class="meta-row"><picker mode="date" value="{{recordDate}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e"><view class="meta-item"><text class="meta-icon">📅</text><text class="meta-text">{{dateDisplay}}</text></view></picker><view class="meta-divider"></view><view class="meta-item meta-remark"><text class="meta-icon">✏️</text><input class="remark-input" placeholder="添加备注..." placeholder-class="remark-placeholder" maxlength="100" data-event-opts="{{[['input',[['__set_model',['','remark','$event',[]]]]]]}}" value="{{remark}}" bindinput="__e"/></view></view><view class="amount-display"><view class="amount-line"></view><view class="amount-row"><text class="amount-symbol">¥</text><text class="amount-value">{{displayAmount}}</text><text class="amount-currency">CNY</text></view></view><view class="keyboard"><view class="keyboard-main"><view class="keyboard-row"><view data-event-opts="{{[['tap',[['inputNumber',['1']]]]]}}" class="key" bindtap="__e"><text>1</text></view><view data-event-opts="{{[['tap',[['inputNumber',['2']]]]]}}" class="key" bindtap="__e"><text>2</text></view><view data-event-opts="{{[['tap',[['inputNumber',['3']]]]]}}" class="key" bindtap="__e"><text>3</text></view></view><view class="keyboard-row"><view data-event-opts="{{[['tap',[['inputNumber',['4']]]]]}}" class="key" bindtap="__e"><text>4</text></view><view data-event-opts="{{[['tap',[['inputNumber',['5']]]]]}}" class="key" bindtap="__e"><text>5</text></view><view data-event-opts="{{[['tap',[['inputNumber',['6']]]]]}}" class="key" bindtap="__e"><text>6</text></view></view><view class="keyboard-row"><view data-event-opts="{{[['tap',[['inputNumber',['7']]]]]}}" class="key" bindtap="__e"><text>7</text></view><view data-event-opts="{{[['tap',[['inputNumber',['8']]]]]}}" class="key" bindtap="__e"><text>8</text></view><view data-event-opts="{{[['tap',[['inputNumber',['9']]]]]}}" class="key" bindtap="__e"><text>9</text></view></view><view class="keyboard-row"><view data-event-opts="{{[['tap',[['clearAmount',['$event']]]]]}}" class="key" bindtap="__e"><text class="key-special">C</text></view><view data-event-opts="{{[['tap',[['inputNumber',['0']]]]]}}" class="key" bindtap="__e"><text>0</text></view><view data-event-opts="{{[['tap',[['inputNumber',['.']]]]]}}" class="key" bindtap="__e"><text>.</text></view></view></view><view class="keyboard-side"><view data-event-opts="{{[['tap',[['backspace',['$event']]]]]}}" class="key key-back" bindtap="__e"><text class="key-back-icon">⌫</text></view><view data-event-opts="{{[['tap',[['saveRecord',['$event']]]]]}}" class="key key-confirm" bindtap="__e"><text class="key-confirm-text">{{isEdit?'保存':'完成'}}</text></view></view></view></view>