<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="nav-bar"><text class="nav-title">{{isEdit?'编辑记录':'记一笔'}}</text></view><view class="type-switch"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="{{['type-item',(type===1)?'active':'']}}" bindtap="__e"><text>支出</text></view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['type-item','income',(type===2)?'active':'']}}" bindtap="__e"><text>收入</text></view></view><view class="amount-section"><text class="amount-symbol">¥</text><text class="amount-value">{{displayAmount}}</text><block wx:if="{{!amount}}"><view class="amount-cursor"></view></block></view><view class="remark-section"><input class="remark-input" placeholder="添加备注..." placeholder-class="remark-placeholder" maxlength="100" data-event-opts="{{[['input',[['__set_model',['','remark','$event',[]]]]]]}}" value="{{remark}}" bindinput="__e"/></view><view class="date-section"><picker mode="date" value="{{recordDate}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e"><view class="date-item"><text class="date-icon">📅</text><text class="date-text">{{dateDisplay}}</text></view></picker></view><view class="category-section"><scroll-view class="category-scroll" scroll-y="{{true}}"><view class="category-grid"><block wx:for="{{categoryList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['selectCategory',['$0'],[[['categoryList','id',item.id]]]]]]]}}" class="{{['category-item',(selectedCategory===item.id)?'active':'']}}" bindtap="__e"><view class="{{['category-icon',(selectedCategory===item.id)?'active':'']}}">{{''+item.icon+''}}</view><text class="category-name">{{item.name}}</text></view></block></view></scroll-view></view><view class="keyboard"><view class="keyboard-row"><view data-event-opts="{{[['tap',[['inputNumber',['1']]]]]}}" class="key" bindtap="__e"><text>1</text></view><view data-event-opts="{{[['tap',[['inputNumber',['2']]]]]}}" class="key" bindtap="__e"><text>2</text></view><view data-event-opts="{{[['tap',[['inputNumber',['3']]]]]}}" class="key" bindtap="__e"><text>3</text></view><view data-event-opts="{{[['tap',[['backspace',['$event']]]]]}}" class="key key-back" bindtap="__e"><text>⌫</text></view></view><view class="keyboard-row"><view data-event-opts="{{[['tap',[['inputNumber',['4']]]]]}}" class="key" bindtap="__e"><text>4</text></view><view data-event-opts="{{[['tap',[['inputNumber',['5']]]]]}}" class="key" bindtap="__e"><text>5</text></view><view data-event-opts="{{[['tap',[['inputNumber',['6']]]]]}}" class="key" bindtap="__e"><text>6</text></view><view data-event-opts="{{[['tap',[['inputNumber',['+']]]]]}}" class="key key-plus" bindtap="__e"><text>+</text></view></view><view class="keyboard-row"><view data-event-opts="{{[['tap',[['inputNumber',['7']]]]]}}" class="key" bindtap="__e"><text>7</text></view><view data-event-opts="{{[['tap',[['inputNumber',['8']]]]]}}" class="key" bindtap="__e"><text>8</text></view><view data-event-opts="{{[['tap',[['inputNumber',['9']]]]]}}" class="key" bindtap="__e"><text>9</text></view><view data-event-opts="{{[['tap',[['saveRecord',['$event']]]]]}}" class="key key-confirm" bindtap="__e"><text>{{isEdit?'保存':'确定'}}</text></view></view><view class="keyboard-row"><view data-event-opts="{{[['tap',[['inputNumber',['0']]]]]}}" class="key key-zero" bindtap="__e"><text>0</text></view><view data-event-opts="{{[['tap',[['inputNumber',['.']]]]]}}" class="key" bindtap="__e"><text>.</text></view><view data-event-opts="{{[['tap',[['clearAmount',['$event']]]]]}}" class="key key-clear" bindtap="__e"><text>C</text></view></view></view></view>