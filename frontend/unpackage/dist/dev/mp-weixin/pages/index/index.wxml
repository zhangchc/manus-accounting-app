<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="header"><view class="header-top"><view class="greeting"><text class="greeting-text">{{greetingText}}</text><text class="greeting-emoji">{{greetingEmoji}}</text></view><view class="header-date">{{todayStr}}</view></view><view class="overview-card"><view class="overview-header"><text data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="overview-month" bindtap="__e">{{monthName}}</text><text data-event-opts="{{[['tap',[['toggleAmount',['$event']]]]]}}" class="overview-eye" bindtap="__e">{{showAmount?'👁':'👁‍🗨'}}</text></view><view class="overview-body"><view class="overview-item"><text class="overview-label">月支出</text><text class="overview-amount expense">{{showAmount?$root.m0:'****'}}</text></view><view class="overview-divider"></view><view class="overview-item"><text class="overview-label">月收入</text><text class="overview-amount income">{{showAmount?$root.m1:'****'}}</text></view><view class="overview-divider"></view><view class="overview-item"><text class="overview-label">月结余</text><text class="overview-amount">{{showAmount?$root.m2:'****'}}</text></view></view><block wx:if="{{budget>0}}"><view class="budget-bar"><view class="budget-info"><text class="budget-text">{{"月预算 ¥"+$root.m3}}</text><text class="{{['budget-remain',(budgetRemain<0)?'over':'']}}">{{''+(budgetRemain>=0?'剩余 ¥'+$root.m4:'超支 ¥'+$root.m5)+''}}</text></view><view class="progress-bg"><view class="{{['progress-bar',(budgetPercent>100)?'over':'']}}" style="{{'width:'+(budgetPercent+'%')+';'}}"></view></view></view></block></view></view><view class="section"><view class="section-header"><text class="section-title">今日账单</text><text data-event-opts="{{[['tap',[['goToBill',['$event']]]]]}}" class="section-more" bindtap="__e">查看全部</text></view><block wx:if="{{$root.g0>0}}"><view class="record-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['longpress',[['onRecordLongPress',['$0'],[[['todayRecords','id',item.$orig.id]]]]]]]}}" class="record-item" bindlongpress="__e"><view class="record-icon">{{item.$orig.categoryIcon}}</view><view class="record-info"><text class="record-category">{{item.$orig.categoryName}}</text><block wx:if="{{item.$orig.remark}}"><text class="record-remark">{{item.$orig.remark}}</text></block></view><text class="{{['record-amount',item.$orig.type===1?'expense':'income']}}">{{''+(item.$orig.type===1?'-':'+')+item.m6+''}}</text></view></block></view></block><block wx:else><view class="empty-state"><text class="empty-icon">📝</text><text class="empty-text">今天还没有记账哦</text><view data-event-opts="{{[['tap',[['goToAdd',['$event']]]]]}}" class="empty-btn" bindtap="__e">记一笔</view></view></block></view><view data-event-opts="{{[['tap',[['goToAdd',['$event']]]]]}}" class="fab-btn" bindtap="__e"><text class="fab-icon">+</text></view></view>