<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="header"><view class="header-top"><view class="greeting-area"><text class="greeting-text">{{greetingText+"，"+userName}}</text><view class="header-date"><text class="date-text">{{todayStr}}</text><text class="date-emoji">{{greetingEmoji}}</text></view></view><view class="user-avatar"><text class="avatar-text">{{avatarText}}</text></view></view><view class="overview-card"><text class="overview-title">本月概览</text><view class="overview-body"><view class="overview-item"><view class="overview-icon-wrap expense-icon"><text class="overview-icon-text">↓</text></view><text class="overview-label">支出</text><text class="overview-amount">{{showAmount?'¥'+$root.m0:'****'}}</text></view><view class="overview-item"><view class="overview-icon-wrap income-icon"><text class="overview-icon-text">↑</text></view><text class="overview-label">收入</text><text class="overview-amount">{{showAmount?'¥'+$root.m1:'****'}}</text></view><view class="overview-item"><view class="overview-icon-wrap balance-icon"><text class="overview-icon-text">⚖</text></view><text class="overview-label">结余</text><text class="overview-amount">{{showAmount?'¥'+$root.m2:'****'}}</text></view></view></view><block wx:if="{{budget>0}}"><view class="budget-section"><view class="budget-info"><text class="budget-label">{{"月预算 ¥"+$root.m3}}</text><text class="{{['budget-remain',(budgetRemain<0)?'over':'']}}">{{''+(budgetRemain>=0?'剩余 ¥'+$root.m4:'超支 ¥'+$root.m5)+''}}</text></view><view class="progress-bg"><view class="{{['progress-bar',(budgetPercent>65)?'warning':'',(budgetPercent>90)?'over':'']}}" style="{{'width:'+(budgetPercent+'%')+';'}}"></view></view></view></block></view><view class="section"><view class="section-header"><text class="section-title">今日账单</text><view data-event-opts="{{[['tap',[['goToBill',['$event']]]]]}}" class="section-more" bindtap="__e"><text class="more-text">查看全部</text><text class="more-arrow">›</text></view></view><block wx:if="{{$root.g0>0}}"><view class="record-list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['longpress',[['onRecordLongPress',['$0'],[[['todayRecords','id',item.$orig.id]]]]]]]}}" class="record-item" bindlongpress="__e"><view class="record-icon-wrap" style="{{'background:'+(item.m6)+';'}}"><image class="record-icon-img" src="{{item.m7}}" mode="aspectFit"></image></view><view class="record-info"><text class="record-category">{{item.$orig.categoryName}}</text><block wx:if="{{item.$orig.remark}}"><text class="record-remark">{{item.$orig.remark}}</text></block><block wx:if="{{item.$orig.recordTime}}"><text class="record-time">{{item.$orig.recordTime?item.g1:''}}</text></block></view><text class="{{['record-amount',item.$orig.type===1?'expense':'income']}}">{{''+(item.$orig.type===1?'-':'+')+"¥"+item.m8+''}}</text></view></block></view></block><block wx:else><view class="empty-state"><image class="empty-icon-img" src="/static/category/qita_out.png" mode="aspectFit"></image><text class="empty-text">今天还没有记账哦</text><view data-event-opts="{{[['tap',[['goToAdd',['$event']]]]]}}" class="empty-btn" bindtap="__e"><text class="empty-btn-text">记一笔</text></view></view></block></view><view data-event-opts="{{[['tap',[['goToAdd',['$event']]]]]}}" class="fab-btn" bindtap="__e"><text class="fab-icon">+</text></view></view>