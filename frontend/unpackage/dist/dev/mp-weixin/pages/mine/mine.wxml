<view class="page"><view class="profile-header"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="profile-content"><view class="avatar-circle"><text class="avatar-letter">{{avatarText}}</text></view><text class="profile-name">{{userInfo.nickName||'记账用户'}}</text><text class="profile-sign">记录生活，理清收支 ✨</text></view><view class="wave-bottom"><view class="wave-shape"></view></view></view><view class="year-card"><text class="year-title">{{currentYear+"年度总结"}}</text><view class="year-data"><view class="year-item"><text class="year-label">总收入</text><text class="year-value income">{{"¥"+$root.m0}}</text></view><view class="year-divider"></view><view class="year-item"><text class="year-label">总支出</text><text class="year-value expense">{{"¥"+$root.m1}}</text></view><view class="year-divider"></view><view class="year-item"><text class="year-label">结余</text><text class="year-value">{{"¥"+$root.m2}}</text></view></view></view><view class="menu-card"><view data-event-opts="{{[['tap',[['goToBill',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-left"><text class="menu-icon">📋</text><text class="menu-name">月度账单</text></view><text class="menu-arrow">›</text></view><view data-event-opts="{{[['tap',[['goToBudget',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-left"><text class="menu-icon">💰</text><text class="menu-name">预算管理</text></view><text class="menu-arrow">›</text></view><view data-event-opts="{{[['tap',[['goToBooks',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-left"><text class="menu-icon">📒</text><text class="menu-name">我的账本</text></view><text class="menu-arrow">›</text></view><view data-event-opts="{{[['tap',[['exportData',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-left"><text class="menu-icon">📤</text><text class="menu-name">数据导出</text></view><text class="menu-arrow">›</text></view><view data-event-opts="{{[['tap',[['showAbout',['$event']]]]]}}" class="menu-item" bindtap="__e"><view class="menu-left"><text class="menu-icon">💡</text><text class="menu-name">关于我们</text></view><text class="menu-arrow">›</text></view></view><view data-event-opts="{{[['tap',[['logout',['$event']]]]]}}" class="logout-btn" bindtap="__e"><text class="logout-text">退出登录</text></view></view>