<view class="page"><view style="{{'height:'+(statusBarHeight+'px')+';'}}"></view><view class="user-card"><view class="user-avatar"><text class="avatar-text">{{avatarText}}</text></view><view class="user-info"><text class="user-name">{{userInfo.nickName||'记账用户'}}</text><text class="user-desc">记录每一笔，生活更美好</text></view></view><view class="year-summary"><view class="year-header"><text class="year-title">{{currentYear+"年汇总"}}</text></view><view class="year-body"><view class="year-item"><text class="year-amount expense">{{"¥"+$root.m0}}</text><text class="year-label">总支出</text></view><view class="year-divider"></view><view class="year-item"><text class="year-amount income">{{"¥"+$root.m1}}</text><text class="year-label">总收入</text></view><view class="year-divider"></view><view class="year-item"><text class="year-amount">{{"¥"+$root.m2}}</text><text class="year-label">结余</text></view></view></view><view class="menu-section"><view class="menu-card"><view data-event-opts="{{[['tap',[['goToBill',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="menu-icon">📋</text><text class="menu-text">月度账单</text><text class="menu-arrow">›</text></view><view data-event-opts="{{[['tap',[['goToBudget',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="menu-icon">🎯</text><text class="menu-text">预算管理</text><text class="menu-arrow">›</text></view><view data-event-opts="{{[['tap',[['goToBooks',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="menu-icon">📒</text><text class="menu-text">我的账本</text><text class="menu-arrow">›</text></view></view><view class="menu-card"><view data-event-opts="{{[['tap',[['exportData',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="menu-icon">📤</text><text class="menu-text">数据导出</text><text class="menu-arrow">›</text></view><view data-event-opts="{{[['tap',[['showAbout',['$event']]]]]}}" class="menu-item" bindtap="__e"><text class="menu-icon">💡</text><text class="menu-text">关于轻记账</text><text class="menu-arrow">›</text></view></view></view></view>